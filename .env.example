# Database (Vercel Postgres)
DATABASE_URL=postgres://user:password@host:5432/eilersfriends?sslmode=require

# NextAuth
AUTH_SECRET=your-secret-here-min-32-chars
AUTH_URL=http://localhost:3000

# Resend (E-Mail)
RESEND_API_KEY=re_your-api-key
EMAIL_FROM=noreply@eilersfriends.com

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_your-token

# Beehiiv (Newsletter)
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=your-publication-id

# Stripe
STRIPE_SECRET_KEY=sk_your-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
